# ============================================
# TRAMOS AI Support System - Environment Configuration
# ============================================
# Copy file ini ke .env dan isi dengan nilai sebenarnya
# JANGAN commit .env ke git - sudah diignore
# Semua secret/token harus di .env, bukan di code

# ============================================
# Application Settings
# ============================================
DEBUG=true
ENVIRONMENT=development

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
# Format: postgresql://user:password@host:port/database
# Port default Docker: 5434 (bukan 5432)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/tramos_db
REDIS_URL=redis://localhost:6379/0
WHATSAPP_DEDUP_TTL_SECONDS=86400
WHATSAPP_TURN_LOCK_TIMEOUT_SECONDS=30
WHATSAPP_TURN_LOCK_TTL_SECONDS=180

# ============================================
# osTicket API Configuration
# ============================================
# URL osTicket API (localhost jika development)
OSTICKET_BASE_URL=http://127.0.0.1/osTicket/api
OSTICKET_API_KEY=your-osticket-api-key-here

# ============================================
# WhatsApp Business API Configuration
# ============================================
# WhatsApp Cloud API - get token dari Meta Business Developer Console
WHATSAPP_API_URL=https://graph.facebook.com/v25.0
WHATSAPP_API_TOKEN=your-whatsapp-token-here
WHATSAPP_PHONE_ID=your-phone-number-id-here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-this-to-random-token

# ============================================
# AI / LLM Configuration
# ============================================
# Provider: gemini atau anthropic
LLM_PROVIDER=anthropic
USE_LLM=true
AI_CONFIDENCE_THRESHOLD=0.7

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=1536

# Embedding/RAG provider. Chat boleh pakai Claude, embedding boleh pakai Ollama.
# Provider: gemini, ollama, atau hash (khusus test/offline).
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=qwen3-embedding:4b
EMBEDDING_DIMENSIONS=2560
# Local/dev default. Untuk production Docker + Ollama, pakai http://ollama:11434.
EMBEDDING_OLLAMA_URL=http://localhost:11434
EMBEDDING_REQUEST_TIMEOUT_SECONDS=180

# Anthropic Claude (jika LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
# Base URL untuk proxy/internal endpoint (kosongkan jika pakai resmi)
ANTHROPIC_BASE_URL=https://ai.bluepack.my.id/anthropic
LLM_REQUEST_TIMEOUT_SECONDS=60

# ============================================
# Knowledge Base / RAG Configuration
# ============================================
# Aktifkan RAG untuk chatbot intelligent (rekomendasi: true)
KB_RAG_ENABLED=true
KB_SOURCE_DIR=knowledge_base
KB_TOP_K=5
KB_MIN_SCORE=0.35
KB_CONTEXT_MAX_CHARS=4500
# KB_PGVECTOR_REQUIRED=false berarti fallback cosine aktif jika pgvector mati
KB_PGVECTOR_REQUIRED=false

# ============================================
# Dashboard Auth
# ============================================
JWT_SECRET_KEY=change-this-to-long-random-secret-key
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-this-admin-password
DASHBOARD_ENABLE_LEGACY_ADMIN=true
TOKEN_EXPIRE_MINUTES=480

# ============================================
# Email Notification (untuk ticket alerts)
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=tramos@tramos.id
OPERATOR_EMAILS=admin@tramos.id,support@tramos.id

# ============================================
# CORS Configuration
# ============================================
# Origins yang diizinkan (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
