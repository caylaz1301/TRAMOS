# ============================================
# TRAMOS AI Support System - Environment Configuration
# ============================================

# Application Settings
# DEBUG mode enables detailed logging
DEBUG=true

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tramos_db

# ============================================
# osTicket API Configuration
# ============================================
# Get your API key from osTicket admin panel: Admin > API Keys
# API URL format: https://your-domain.com/osticket/api
OSTICKET_BASE_URL=https://your-domain.com/osticket/api
OSTICKET_API_URL=https://your-domain.com/osticket/api
OSTICKET_API_KEY=your-osticket-api-key-here
OSTICKET_TICKETS_ENDPOINT=/api/tickets.json
DEFAULT_TICKET_IP=127.0.0.1
DEFAULT_TICKET_PRIORITY=normal

# ============================================
# WhatsApp Business API Configuration
# ============================================
# For Meta WhatsApp Business API use: https://graph.facebook.com/v19.0
# Get your token from Meta Business Developer Console
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_API_TOKEN=your-whatsapp-token-here
WHATSAPP_PHONE_ID=your-phone-number-id-here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=tramos_webhook_token_change_me

# ============================================
# Webhook Configuration
# ============================================
# Webhook verification token - change this to a strong random value in production
WEBHOOK_VERIFY_TOKEN=tramos_webhook_token_change_me

# ============================================
# AI / LLM Configuration (Local Ollama)
# ============================================
# Using local Ollama + Mistral model for AI processing
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
USE_LLM=true
AI_CONFIDENCE_THRESHOLD=0.7

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins, or * for all
CORS_ORIGINS=*
