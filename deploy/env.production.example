# Copy ke deploy/env.production di VPS, lalu isi secret asli.
# Jangan commit file deploy/env.production.

# Docker database bootstrap
TRAMOS_POSTGRES_DB=tramos_db
TRAMOS_POSTGRES_USER=tramos
TRAMOS_POSTGRES_PASSWORD=change-this-postgres-password
TRAMOS_POSTGRES_HOST_PORT=5434
TRAMOS_BACKEND_HOST_PORT=9999
TRAMOS_REDIS_HOST_PORT=6379
REDIS_URL=redis://redis:6379/0
WHATSAPP_DEDUP_TTL_SECONDS=86400
WHATSAPP_TURN_LOCK_TIMEOUT_SECONDS=30
WHATSAPP_TURN_LOCK_TTL_SECONDS=180
UVICORN_WORKERS=1

# Application
ENVIRONMENT=production
DEBUG=false
APP_NAME=TRAMOS AI Support System
APP_VERSION=1.0.0
DATABASE_URL=postgresql://tramos:change-this-postgres-password@postgres:5432/tramos_db
CORS_ORIGINS=https://dashboard.example.com

# WhatsApp Cloud API
WHATSAPP_API_URL=https://graph.facebook.com/v25.0
WHATSAPP_API_TOKEN=replace-with-production-token
WHATSAPP_PHONE_ID=replace-with-phone-number-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-random-verify-token
WHATSAPP_MODE=production

# osTicket production URL
OSTICKET_BASE_URL=https://support.example.com/osTicket/api
OSTICKET_API_URL=https://support.example.com/osTicket/api
OSTICKET_API_KEY=replace-with-osticket-api-key
OSTICKET_TICKETS_ENDPOINT=/tickets.json
DEFAULT_TICKET_IP=127.0.0.1
DEFAULT_TICKET_PRIORITY=normal

# LLM chat provider
LLM_PROVIDER=anthropic
USE_LLM=true
AI_CONFIDENCE_THRESHOLD=0.7
ANTHROPIC_API_KEY=replace-with-anthropic-or-bluepack-key
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=https://ai.bluepack.my.id/anthropic
LLM_REQUEST_TIMEOUT_SECONDS=60

# Gemini fallback, optional
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# RAG / embedding
# Penting:
# - Jangan pakai server Ollama kantor untuk production client kecuali ada izin resmi,
#   jaringan aman/VPN, dan client setuju data pertanyaannya lewat server tersebut.
# - Rekomendasi production mandiri: jalankan Ollama di VPS client, lalu pakai
#   EMBEDDING_OLLAMA_URL=http://ollama:11434 dengan docker-compose.ollama.yml.
# - Alternatif managed: pakai EMBEDDING_PROVIDER=gemini dan isi GEMINI_API_KEY.
KB_RAG_ENABLED=true
KB_SOURCE_DIR=knowledge_base
KB_TOP_K=5
KB_MIN_SCORE=0.35
KB_CONTEXT_MAX_CHARS=4500
KB_PGVECTOR_REQUIRED=false
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=qwen3-embedding:4b
EMBEDDING_DIMENSIONS=2560
EMBEDDING_OLLAMA_URL=http://ollama:11434
EMBEDDING_REQUEST_TIMEOUT_SECONDS=180
AUTO_INGEST_KB=false

# Dashboard auth
JWT_SECRET_KEY=replace-with-64-char-random-secret
DASHBOARD_ENABLE_LEGACY_ADMIN=false
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
GOOGLE_CLIENT_ID=139927891496-mjf7sfmurd3o3alpecvhn9gum5aqj059.apps.googleusercontent.com
TOKEN_EXPIRE_MINUTES=480

# Email notification, optional
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@tramos.local
SMTP_USE_TLS=true
OPERATOR_EMAILS=
